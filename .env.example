# ═══════════════════════════════════════════════════
# AZHL أزهل — Environment Variables
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anthropic Claude AI (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# WhatsApp API (360dialog Dashboard)
WHATSAPP_API_KEY=your-360dialog-api-key
WHATSAPP_VERIFY_TOKEN=azhl-verify-2026

# Stripe Payments (dashboard.stripe.com → Developers → API Keys)
STRIPE_SECRET_KEY=sk_live_your-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Push Notifications — VAPID Keys
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_EMAIL=mailto:hello@azhl.ai

# App
NEXT_PUBLIC_APP_URL=https://azhl.ai
